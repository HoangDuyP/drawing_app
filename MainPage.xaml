<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="drawing_app.MainPage">
    <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" Padding="10" BackgroundColor="#EEE">
            <Grid ColumnDefinitions="Auto, 10, Auto, 10, Auto, *, Auto" RowDefinitions="Auto, Auto" Padding="10">
                <HorizontalStackLayout Grid.Row="0" Grid.Column="0"  Spacing="10" BackgroundColor="White">
                    <Button Style="{StaticResource ShapesButtonStyle}" ImageSource="dot.png" WidthRequest="50" HeightRequest="50" BackgroundColor="Transparent" Clicked="OnDotClicked"/>
                    <Button Style="{StaticResource ShapesButtonStyle}" ImageSource="line.png" WidthRequest="50" HeightRequest="50" BackgroundColor="Transparent" Clicked="OnLineClicked"/>
                    <Button Style="{StaticResource ShapesButtonStyle}" ImageSource="ellipse.png" WidthRequest="50" HeightRequest="50" BackgroundColor="Transparent" Clicked="OnEllipseClicked"/>
                    <Button Style="{StaticResource ShapesButtonStyle}" ImageSource="circle.png" WidthRequest="50" HeightRequest="50" BackgroundColor="Transparent" Clicked="OnCircleClicked"/>
                    <Button Style="{StaticResource ShapesButtonStyle}" ImageSource="square.png" WidthRequest="50" HeightRequest="50" BackgroundColor="Transparent" Clicked="OnSquareClicked"/>
                    <Button Style="{StaticResource ShapesButtonStyle}" ImageSource="rectangle.png" WidthRequest="50" HeightRequest="50" BackgroundColor="Transparent" Clicked="OnRectangleClicked"/>
                </HorizontalStackLayout>
                <Label Grid.Row="1" Grid.Column="0" BackgroundColor="Transparent" HorizontalTextAlignment="Center" Padding="0, 10, 0, 0">
                    Shapes
                </Label>

                <BoxView Grid.Row="0" Grid.Column="2" x:Name="CurrentColorBox" WidthRequest="40" HeightRequest="40" CornerRadius="100" Color="Red"/>
                <Label Grid.Row="1" Grid.Column="2" BackgroundColor="Transparent" HorizontalTextAlignment="Center" Padding="0, 10, 0, 0">
                    Current color
                </Label>
                <HorizontalStackLayout Grid.Row="0" Grid.Column="4"  Spacing="10" BackgroundColor="White">
                    <Button Style="{StaticResource ColorButtonStyle}" WidthRequest="20" HeightRequest="20"/>
                    <Button Style="{StaticResource ColorButtonStyle}" WidthRequest="20" HeightRequest="20"/>
                    <Button Style="{StaticResource ColorButtonStyle}" WidthRequest="40" HeightRequest="40"/>
                    <Button Style="{StaticResource ColorButtonStyle}" WidthRequest="40" HeightRequest="40"/>
                    <Button Style="{StaticResource ColorButtonStyle}" WidthRequest="40" HeightRequest="40"/>
                    <Button Style="{StaticResource ColorButtonStyle}" WidthRequest="40" HeightRequest="40"/>
                    <Button Style="{StaticResource ColorButtonStyle}" WidthRequest="40" HeightRequest="40"/>
                    <Button Style="{StaticResource ColorButtonStyle}" WidthRequest="40" HeightRequest="40"/>
                    <Button Style="{StaticResource ColorButtonStyle}" WidthRequest="40" HeightRequest="40"/>
                    
                </HorizontalStackLayout>
                <Label Grid.Row="1" Grid.Column="4" BackgroundColor="Transparent" HorizontalTextAlignment="Center" Padding="0, 10, 0, 0">
                    Colors
                </Label>
                <HorizontalStackLayout Grid.Row="0" Grid.Column="6" Spacing="10">
                    <Button Style="{StaticResource SaveButtonStyle}" Text="SAVE"/>
                    <Button Style="{StaticResource LoadButtonStyle}" Text="LOAD"/>
                    <Button Style="{StaticResource NewButtonStyle}" Text="NEW"/>
                </HorizontalStackLayout>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
